---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../../utils/readingTime";
import { getEntrySlug } from "../../utils/contentSlug";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  title="Blog"
  description="Essays and field notes by Abdullah Mohsin Naqvi."
>
  <section class="prose" aria-labelledby="blog-heading">
    <header>
      <h1 id="blog-heading">Blog</h1>
      <p>
    Notes on building systems and figuring out why they behave the way they do. Some are experiments. Some are deployed. Most are still being figured out.
      </p>
    </header>

    {posts.length === 0 ? (
      <p>No posts yet.</p>
    ) : (
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/blog/${getEntrySlug(post)}`}>{post.data.title}</a>
            <br />
            <span class="meta meta-row meta-row-inline">
              <time datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "2-digit",
                })}
              </time>
              <span>{getReadingTime(post.body)}</span>
            </span>
            <p>{post.data.description}</p>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

