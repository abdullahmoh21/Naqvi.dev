---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

function getReadingTime(text) {
  const words = text.trim().split(/\s+/).filter(Boolean).length;
  const minutes = Math.max(1, Math.ceil(words / 200));
  return `${minutes} min read`;
}

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  title="Blog"
  description="Essays and field notes by Abdullah Mohsin Naqvi."
>
  <section class="prose" aria-labelledby="blog-heading">
    <header>
      <h1 id="blog-heading">Blog</h1>
      <p>
        Long-form notes on developer tools, programming languages, and the craft of
        debugging and design. Many entries are living documents and may evolve over time.
      </p>
    </header>

    {posts.length === 0 ? (
      <p>No posts yet.</p>
    ) : (
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            <br />
            <span class="meta">
              {post.data.publishedAt.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit",
              })}
              {" · "}
              {getReadingTime(post.body)}
            </span>
            <p>{post.data.description}</p>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

