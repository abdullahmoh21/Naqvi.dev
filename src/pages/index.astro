---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { getEntrySlug } from "../utils/contentSlug";

const [homeEntry] = await getCollection("home");
const homeContent = homeEntry ? await render(homeEntry) : null;
const [nowEntry] = await getCollection("homeNow");
const nowContent = nowEntry ? await render(nowEntry) : null;

const allProjects = (
  await getCollection("projects")
)
  .filter((project) => !getEntrySlug(project).startsWith("_"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const configuredSelectedProjects = (homeEntry?.data.selectedProjectSlugs ?? [])
  .map((slug) =>
    allProjects.find((project) => getEntrySlug(project) === slug),
  )
  .filter(
    (project): project is (typeof allProjects)[number] => project !== undefined,
  );

const selectedProjects =
  configuredSelectedProjects.length > 0
    ? configuredSelectedProjects
    : allProjects.slice(0, 3);
const recentPosts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 5);
---

<BaseLayout
  title="Home"
  description="Notebook of Abdullah Mohsin Naqvi — essays, project logs, and experiments in developer tools."
>
  <section class="prose">
    {homeContent ? <homeContent.Content /> : null}

    <h2>Selected Projects</h2>
    {selectedProjects.length === 0 ? (
      <p>No projects yet.</p>
    ) : (
      <ul>
        {selectedProjects.map((project) => (
          <li>
            <a href={`/projects/${getEntrySlug(project)}`}>{project.data.title}</a>
          </li>
        ))}
      </ul>
    )}

    <h2>Recent Writings</h2>
    {recentPosts.length === 0 ? (
      <p>No posts yet.</p>
    ) : (
      <ul class="home-post-list">
        {recentPosts.map((post) => (
          <li class="home-post-row">
            <a class="home-post-title" href={`/blog/${getEntrySlug(post)}`}>
              {post.data.title}
            </a>
            <p class="home-post-excerpt">{post.data.description}</p>
            <time class="meta home-post-date" datetime={post.data.publishedAt.toISOString()}>
              Published {post.data.publishedAt.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit",
              })}
            </time>
          </li>
        ))}
      </ul>
    )}

    <h2>Now</h2>
    {nowContent ? (
      <nowContent.Content />
    ) : (
      <p>
       Currently exploring new systems, refining old ideas, and figuring things out in public.
      </p>
    )}
  </section>
</BaseLayout>

